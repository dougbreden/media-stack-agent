# Secrets — never commit
.env
api-keys.md
*.conf

# Service config databases and generated files
config/

# Media files
data/

# Config backups (can be large zips — store externally, not in git)
backups/

# Generated cache files
library-report-cache.json

# Diagnostic / temp scripts (prefixed _ by convention)
scripts/_*

# Credentials config (actual values — never commit, see config.ps1.example)
scripts/config.ps1

# Runtime state (machine-specific, not source)
.standardize-last-run
logs/
.claude/scheduled_tasks.lock

# Unused scaffolding files
package.json
package-lock.json

# Stray path-mangled temp file (Windows Temp path written with unicode colon)
C*Temp*.json

# Windows
Thumbs.db
desktop.ini
