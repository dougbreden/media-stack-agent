# Copy this file to .env and fill in real values. Never commit .env.
#
# Mullvad WireGuard credentials
# Download a WireGuard config from mullvad.net → WireGuard keys → generate → download .conf
# PrivateKey line  → WIREGUARD_PRIVATE_KEY
# Address line     → WIREGUARD_ADDRESSES (IPv4 only, e.g. 10.64.16.116/32)
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# Radarr API key — Radarr → Settings → General → Security → API Key
RADARR_API_KEY=

# Sonarr API key — Sonarr → Settings → General → Security → API Key
SONARR_API_KEY=
